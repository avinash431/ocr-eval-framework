      "block_id": "20260328_f2b40f9e-5bdb-4380-ad1c-d7d4e41fe509_1_block_011",
      "coordinates": {
        "x1": 9.0,
        "y1": 476.0,
        "x2": 303.0,
        "y2": 492.0
      },
      "layout_tag": "section-title",
      "confidence": 0.6954026818275452,
      "reading_order": 12,
      "text": "Describe Possible Solutions and Benefits:"
    },
